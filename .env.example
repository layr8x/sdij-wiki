# =============================================================================
# AMS Wiki — 환경 변수 설정
# =============================================================================
# 이 파일을 .env 로 복사한 후 값을 채워주세요.
# cp .env.example .env

# =============================================================================
# Supabase (필수 — DB + Auth)
# =============================================================================
# Supabase 프로젝트 URL  (예: https://abcdefg.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon key (공개 키)
VITE_SUPABASE_ANON_KEY=

# =============================================================================
# Atlassian OAuth 2.0 (선택 — Jira/Confluence OAuth 인증)
# =============================================================================
# OAuth를 통해 API 토큰 노출 없이 안전한 인증을 제공합니다.
# Atlassian App Registry에서 OAuth 앱 등록 후 아래 값들을 채웁니다.
# 참고: https://developer.atlassian.com/cloud/jira/platform/oauth-2-3lo-apps/
#
# Atlassian Cloud의 "OAuth 2.0 (3LO)" 앱에서:
# 1. 클라이언트 ID
ATLASSIAN_OAUTH_CLIENT_ID=
# 2. 클라이언트 시크릿 (매우 민감함!)
ATLASSIAN_OAUTH_CLIENT_SECRET=
# 3. 리다이렉트 URI (Vercel: https://your-domain.vercel.app/api/oauth/callback)
ATLASSIAN_OAUTH_REDIRECT_URI=http://localhost:5173/api/oauth/callback

# =============================================================================
# Confluence API (선택 — 이미지 프록시 + 콘텐츠 동기화)
# =============================================================================
# 모든 Confluence 인증은 서버 사이드에서만 처리합니다.
#  - prod: Vercel Serverless Function (api/confluence-img/[...path].js)
#  - dev : vite.config.js 의 dev 프록시 (동일 서버-사이드 자격증명 사용)
#  - sync: scripts/sync-confluence.mjs (.env.local 직접 읽음)
# VITE_ 접두사는 절대 붙이지 마세요. 클라이언트 번들로 유출됩니다.
#
# OAuth 사용 시 아래 옵션은 선택사항입니다 (레거시 Basic auth 지원).
CONFLUENCE_EMAIL=
CONFLUENCE_TOKEN=
CONFLUENCE_DOMAIN=hiconsy.atlassian.net
CONFLUENCE_SPACE_KEY=FVSOL
CONFLUENCE_ROOT_PAGE_ID=1378910256

# =============================================================================
# Anthropic Claude API (선택 — 검색 AI 요약 카드)
# =============================================================================
# Vercel Serverless Function(api/search-summary.js) 에서만 사용됩니다.
# 클라이언트 번들에 노출되지 않도록 반드시 VITE_ 접두사 없이 설정하세요.
# 값이 비어있으면 검색 오버레이는 AI 요약 카드를 자동으로 숨깁니다.
ANTHROPIC_API_KEY=

# =============================================================================
# Cron Job 보안 (선택 — Vercel Cron 동기화)
# =============================================================================
# Vercel Cron Job 접근 제어용 시크릿
# 랜덤 문자열 생성 권장: openssl rand -hex 32
CRON_SECRET=your_cron_secret_here

# =============================================================================
# 앱 설정
# =============================================================================
VITE_ENV=development
VITE_API_BASE_URL=http://localhost:5173

# =============================================================================
# 카카오 비즈니스 채팅 자동 수집 (선택 — scripts/sync-kakao-chats.mjs)
# =============================================================================
# 마이클래스 CS 분석 데이터셋(src/data/csInsights.js)의 원본 카카오 비즈니스
# 채팅 CSV를 사용자 PC에서 자동 추출하기 위한 설정.
# 상세 가이드: scripts/README-kakao-sync.md
#
# 보안 주의: KAKAO_BUSINESS_COOKIE 는 사용자 카카오 계정 로그인 권한과 동등.
# 절대 git 에 커밋하지 말 것 (.env.local 사용 권장).
KAKAO_BUSINESS_COOKIE=
KAKAO_CHANNEL_ID=
KAKAO_OUTPUT_CSV=
KAKAO_MAX_THREADS=0
KAKAO_HEADLESS=true
KAKAO_MASK_PII=true
KAKAO_SINCE_DAYS=0

# =============================================================================
# 카카오 파트너센터 실시간 수집 (선택 — scripts/kakao-partner-stream.mjs)
# =============================================================================
# business.kakao.com 파트너센터의 채팅을 SockJS WebSocket 으로 실시간 수집.
# 상세: docs/KAKAO_PARTNER_SETUP.md
#
# 보안 주의: KAKAO_PARTNER_COOKIE 는 카카오 계정 로그인 권한과 동등.
# 절대 git/브라우저/Slack 에 노출하지 말 것 (.env.local 만 사용).
KAKAO_PARTNER_PROFILE_ID=_VGAQn
KAKAO_PARTNER_COOKIE=
# Supabase service_role key (스크립트 전용 — RLS 우회).
# anon key 와 다름. Supabase Dashboard > Project Settings > API.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 옵션 (기본값으로 충분)
KAKAO_PARTNER_PAGE_SIZE=100
KAKAO_PARTNER_MAX_PAGES=50
KAKAO_PARTNER_POLL_MS=60000
KAKAO_PARTNER_DUMP_RAW=true
KAKAO_PARTNER_DUMP_PATH=./kakao-partner-raw.log
