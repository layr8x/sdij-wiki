{
  "name": "sdij-wiki",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:e2e": "playwright test",
    "db:seed": "node supabase/generate-seed.mjs",
    "sync:confluence": "node scripts/sync-confluence.mjs",
    "sync:kakao-chats": "node scripts/sync-kakao-chats.mjs",
    "classify:kakao": "node scripts/classify-kakao-csv.mjs",
    "classify:kakao:db": "node --env-file=.env.local scripts/classify-kakao-stream.mjs",
    "update:cs-insights": "node scripts/update-cs-insights.mjs",
    "cs-pipeline": "npm run sync:kakao-chats && node scripts/run-cs-pipeline.mjs",
    "kakao:bootstrap": "node --env-file=.env.local scripts/kakao-partner-bootstrap.mjs",
    "kakao:backfill": "node --env-file=.env.local scripts/kakao-partner-backfill.mjs",
    "kakao:stream": "node --env-file=.env.local scripts/kakao-partner-stream.mjs",
    "kakao:bootstrap:all": "node --env-file=.env.local scripts/kakao-partner-run-all.mjs kakao-partner-bootstrap.mjs",
    "kakao:backfill:all": "node --env-file=.env.local scripts/kakao-partner-run-all.mjs kakao-partner-backfill.mjs",
    "kakao:stream:all": "node --env-file=.env.local scripts/kakao-partner-multi-stream.mjs",
    "kakao:status": "node --env-file=.env.local scripts/kakao-partner-status.mjs",
    "kakao:refresh-cookie": "node scripts/kakao-partner-refresh-cookie.mjs",
    "kakao:export": "node --env-file=.env.local scripts/kakao-partner-export-csv.mjs",
    "kakao:dashboard": "node --env-file=.env.local scripts/kakao-partner-dashboard.mjs",
    "kakao:sheets-sync": "node --env-file=.env.local scripts/kakao-partner-sheets-sync.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/supabase-js": "^2.107.0",
    "@tabler/icons-react": "^3.44.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-table": "^8.21.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "esbuild": "^0.28.0",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "shadcn": "^4.10.0",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
